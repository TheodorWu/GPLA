    "version": "0.2.0",
    "configurations": [
        {
            "name": "Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
         {
            "name": "VLA",
            "type": "debugpy",
            "request": "launch",
            "module": "model.vla",
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}",
            "env": {
                "USE_TORCH": "1"
            }
        },
        {
            "name": "main Dummy",
            "type": "debugpy",
            "request": "launch",
            "program": "main.py",
            "args": [
                "stage=local_dev",
                "model.processor.use_extra=False"
            ],
            "console": "integratedTerminal",
            "env": {
                "BNB_ACTIVE": "True",
                // "TORCH_LOGS":"+dynamo",
                // "TORCHDYNAMO_VERBOSE":"1",
                "WANDB_MODE": "offline"
            },
            // "justMyCode": false,
        },
        {
